# Deployer private key (must be funded on target network)
PRIVATE_KEY=

# Oracle address (signs attestation envelopes — typically derived from the same key)
ORACLE_ADDRESS=

# Arbitrum Sepolia RPC
ARB_SEPOLIA_RPC_URL=

# Arbiscan API key (for contract verification — get one at https://arbiscan.io/myapikey)
ARBISCAN_API_KEY=

# Pass/fail threshold (basis points, default 4000 = 40%)
THRESHOLD=4000
